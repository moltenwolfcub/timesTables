<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="12dp"
    android:paddingHorizontal="8dp"
    android:layout_marginBottom="4dp"
    android:background="@color/container_primary">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.3"
        android:orientation="vertical">
        <TextView
            android:id="@+id/row_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="09 Jun 2026 16:42"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/history_date"/>
        <TextView
            android:id="@+id/row_player_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Player: Guest"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/row_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="25 Problems"
            android:textColor="@color/simple_text"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/row_table_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        tools:text="Max Table: 12"
        android:textColor="@color/simple_text"
        android:textSize="14sp"
        android:layout_gravity="center_vertical"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.2"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center_vertical">

        <View
            android:id="@+id/rosette_1"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/ic_rosette_history" />

        <View
            android:id="@+id/rosette_2"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginBottom="5dp"
            android:background="@drawable/ic_rosette_history" />

        <View
            android:id="@+id/rosette_3"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/ic_rosette_history" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/row_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="1.234s avg"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/row_consistency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/consistency"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="0.12s dev" />

    </LinearLayout>

</LinearLayout>