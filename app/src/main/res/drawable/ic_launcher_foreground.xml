<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:pivotX="54"
        android:pivotY="54">

        <!-- LAYER 1: Deep Silhouette Shadow for the X -->
        <path
            android:pathData="M 38,38 L 70,70 M 70,38 L 38,70"
            android:strokeColor="#020617"
            android:strokeWidth="16"
            android:strokeLineCap="round"/>

        <!-- LAYER 2: Main Cyan Outer Neon Tube -->
        <path
            android:pathData="M 38,38 L 70,70 M 70,38 L 38,70"
            android:strokeColor="#38BDF8"
            android:strokeWidth="10"
            android:strokeLineCap="round"/>

        <!-- LAYER 3: Blended Soft Neon Core (Desaturated White) -->
        <path
            android:pathData="M 38,38 L 70,70 M 70,38 L 38,70"
            android:strokeColor="#E0F2FE"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"/>


        <!-- LAYER 4: Re-Centred & Elevated Gradient Lightning Bolt -->
        <path
            android:pathData="M 57,23
                              L 42,50
                              L 53,50
                              L 41,85
                              L 64,54
                              L 53,54
                              Z"
            android:strokeColor="#0F172A"
            android:strokeWidth="2.5"
            android:strokeLineJoin="round">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="54"
                    android:startY="23"
                    android:endX="54"
                    android:endY="85"
                    android:type="linear">
                    <item android:offset="0.0" android:color="#FDE047"/> <!-- Hot Electric Yellow -->
                    <item android:offset="0.5" android:color="#FBBF24"/> <!-- Warm Gold -->
                    <item android:offset="1.0" android:color="#D97706"/> <!-- Amber Bronze Base -->
                </gradient>
            </aapt:attr>
        </path>

    </group>
</vector>